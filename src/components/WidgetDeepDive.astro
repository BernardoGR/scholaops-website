---
---
<section class="dark-section" id="widget">
  <div class="wrap">
    <div class="showcase-grid reverse">
      <div class="showcase-text reveal">
        <span class="section-eyebrow on-dark">/ El widget</span>
        <h2>
          Atención entrante en piloto automático.<br/>
          <span class="italic">Resultados en el dashboard.</span>
        </h2>
        <p>
          Inserta una línea de código en el sitio de tu escuela. Ada empieza a responder — en el idioma de la familia, con la voz de tu institución, sobre los programas y fechas reales de tu campus.
        </p>
        <ul class="showcase-list">
          <li><span class="check">✓</span>Califica prospectos 24/7 con los programas y fechas reales de tu escuela</li>
          <li><span class="check">✓</span>Conecta el chat web con WhatsApp — sin perder contexto</li>
          <li><span class="check">✓</span>Pasa el lead a una persona en cuanto la intención cruza el umbral</li>
          <li><span class="check">✓</span>Conoce tu tabla de colegiaturas, calendario y FAQ — desde una sola fuente de verdad</li>
        </ul>
      </div>

      <div class="widget-showcase reveal d1" aria-hidden="true">
        <div class="widget-bg"></div>

        <div class="widget-callout tag-extract">
          <div class="ce-lbl">Extraído del chat automáticamente</div>
          <div class="ce-chips">
            <span>1.º secundaria</span>
            <span>Ago 2026</span>
            <span class="cold">Preguntó colegiatura</span>
            <span class="line">Pidió visita</span>
            <span class="line">2 hermanos</span>
          </div>
        </div>

        <div class="widget-frame">
          <div class="wf-head">
            <div class="wf-av"></div>
            <div>
              <h6>Ada — Agente de Admisiones</h6>
              <p>Instituto Ejemplo · en/es</p>
            </div>
          </div>
          <div class="wf-body" id="widgetChat"></div>
          <div class="wf-input">
            <div class="fi">Responde a Ada…</div>
            <div class="send">↑</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .widget-showcase {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 540px;
    margin: 0 auto;
  }
  .widget-bg {
    position: absolute; inset: 0;
    background: radial-gradient(circle at 50% 50%, rgba(215,242,107,0.18), transparent 60%);
    filter: blur(60px);
  }

  /* Callout card — top-left, overlapping widget frame */
  .widget-callout {
    position: absolute;
    background: var(--color-paper);
    border: 1px solid var(--color-ink-line);
    border-radius: 14px;
    padding: 12px 16px;
    box-shadow: var(--shadow-lg);
    color: var(--color-ink);
    z-index: 4;
    animation: bob 5s ease-in-out infinite alternate;
  }
  .widget-callout.tag-extract {
    top: 8%; left: -2%;
    width: 240px;
    animation-delay: -1.5s;
  }
  .ce-lbl {
    font-family: var(--font-mono); font-size: 9px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-mute);
  }
  .ce-chips { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 8px; }
  .ce-chips span {
    padding: 3px 8px; background: var(--color-lime); border-radius: 999px;
    font-family: var(--font-mono); font-size: 10px; font-weight: 600;
    color: var(--color-moss);
  }
  .ce-chips span.cold { background: rgba(127,181,229,0.3); color: #2C5C8F; }
  .ce-chips span.line { background: var(--color-cream); color: var(--color-ink); border: 1px solid var(--color-ink-line); }

  /* Widget frame — bottom-right, absolutely placed */
  .widget-frame {
    position: absolute;
    right: 5%; bottom: 5%;
    width: 70%; max-width: 340px;
    background: var(--color-paper);
    border-radius: 22px;
    box-shadow: 0 40px 80px rgba(0,0,0,0.4), 0 12px 24px rgba(0,0,0,0.2);
    overflow: hidden;
    border: 1px solid rgba(242,239,230,0.1);
  }
  .wf-head {
    padding: 16px 16px 12px; display: flex; align-items: center; gap: 10px;
    background: var(--color-cream);
    border-bottom: 1px solid var(--color-ink-line);
  }
  .wf-av {
    width: 36px; height: 36px; border-radius: 50%; background: var(--color-ink);
    display: inline-flex; align-items: center; justify-content: center;
    position: relative; flex-shrink: 0;
  }
  .wf-av::before { content: ''; position: absolute; inset: 8px; background: var(--color-lime); border-radius: 4px; transform: rotate(45deg) scale(0.85); }
  .wf-av::after  { content: ''; position: absolute; left: 50%; top: 50%; width: 6px; height: 6px; border-radius: 50%; background: var(--color-ink); transform: translate(-50%,-50%); }
  .wf-head h6 { font-size: 13px; font-weight: 600; color: var(--color-ink); }
  .wf-head p  { font-size: 10px; color: var(--color-ink-mute); font-family: var(--font-mono); }
  .wf-body {
    padding: 16px;
    display: flex; flex-direction: column; justify-content: flex-end; gap: 8px;
    height: 240px; overflow: hidden;
    background: linear-gradient(180deg, var(--color-paper) 0%, var(--color-cream) 100%);
  }
  /* Dynamically created bubbles don't carry Astro's scope attr — use :global */
  :global(.wf-body .bubble.in) {
    color: var(--color-ink);
    background: rgba(255,255,255,0.9);
    border: 1px solid var(--color-ink-line);
  }
  .wf-input {
    padding: 10px 14px;
    border-top: 1px solid var(--color-ink-line);
    display: flex; align-items: center; gap: 8px;
    background: var(--color-paper);
  }
  .fi {
    flex: 1; padding: 8px 14px; border-radius: 999px;
    background: var(--color-cream); font-size: 12px; color: var(--color-ink-mute);
    border: 1px solid var(--color-ink-line);
  }
  .send {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--color-lime); color: var(--color-moss);
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700; flex-shrink: 0;
  }
</style>

<script>
  const widgetChat = document.getElementById('widgetChat');
  const widgetScript = [
    { kind: 'ai',     text: 'Hola, soy Ada 👋 ¿En qué puedo ayudarte hoy?' },
    { kind: 'out',    text: 'Quiero info sobre admisiones para mi hija.' },
    { kind: 'ai',     text: '¡Con gusto! ¿En qué grado entraría y para cuándo?' },
    { kind: 'out',    text: '1.º de secundaria, en agosto.' },
    { kind: 'typing' },
    { kind: 'ai',     text: 'Perfecto — aún quedan 4 lugares para Ago 2026 ✨ ¿Tiene hermanos que también entrarían?' },
    { kind: 'out',    text: 'Sí, 2 hermanitos más.' },
    { kind: 'ai',     text: '10% en el 2.º, 15% en el 3.º 🎉 ¿Te armo una cotización para los tres?' },
  ];

  function wait(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  async function runWidgetChat() {
    if (!widgetChat) return;
    widgetChat.innerHTML = '';
    for (const m of widgetScript) {
      if (m.kind === 'typing') {
        const t = document.createElement('div');
        t.className = 'typing';
        t.innerHTML = '<i></i><i></i><i></i>';
        widgetChat.appendChild(t);
        await wait(1100);
        t.remove();
        continue;
      }
      const b = document.createElement('div');
      b.className = 'bubble ' + m.kind;
      if (m.kind === 'ai') {
        b.innerHTML = '<div class="tag"><span class="pulse-s"></span>Ada · AI</div>' + (m.text ?? '');
      } else {
        b.textContent = m.text ?? '';
      }
      widgetChat.appendChild(b);
      await wait(m.kind === 'in' ? 1600 : 2000);
    }
    await wait(1400);
    runWidgetChat();
  }
  runWidgetChat();
</script>
