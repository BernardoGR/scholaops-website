---
<section class="pilot-section">
  <div class="wrap">
    <div class="pilot-label">Piloteando con</div>
    <div class="pilot-row">
      <span class="pilot-name">Via Diseño</span>
      <span class="pilot-divider"></span>
      <span class="pilot-meta">En vivo · cohorte Otoño 2026</span>
    </div>
  </div>
</section>

<style>
  .pilot-section {
    padding: 32px 0 64px;
    border-top: 1px solid var(--color-ink-line);
  }
  .pilot-label {
    font-family: var(--font-mono); font-size: 11px;
    text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--color-ink-mute); margin-bottom: 16px;
  }
  .pilot-row {
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  .pilot-name {
    font-family: var(--font-serif); font-style: italic;
    font-size: 28px; color: var(--color-ink);
  }
  .pilot-divider {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--color-ink-line);
  }
  .pilot-meta {
    font-family: var(--font-mono); font-size: 12px;
    color: var(--color-ink-mute); text-transform: uppercase; letter-spacing: 0.1em;
  }
</style>
