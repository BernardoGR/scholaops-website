---
---
<section class="dark-section" id="crm" style="background: var(--color-ink-2);">
  <div class="wrap">
    <div class="showcase-grid">
      <div class="showcase-text reveal">
        <span class="section-eyebrow on-dark">/ El CRM</span>
        <h2>
          Deja de perseguir.<br/>
          <span class="italic">Empieza a cerrar.</span>
        </h2>
        <p>
          El pipeline se ordena solo. Cada conversación, visita a la página y correo abierto alimenta un score — para que el lunes tu equipo trabaje la lista caliente, no el inbox.
        </p>
        <ul class="showcase-list">
          <li><span class="check">✓</span>Kanban drag-and-drop en 7 etapas de admisiones</li>
          <li><span class="check">✓</span>Lead scoring entrenado con tus propios datos de conversión</li>
          <li><span class="check">✓</span>WhatsApp, correo y llamadas en un clic — todo registrado automáticamente</li>
          <li><span class="check">✓</span>Reportes de embudo que tu directora sí va a abrir</li>
        </ul>
      </div>

      <div class="reveal d1">
        <div class="device">
          <div class="device-screen">
            <div class="crm-mock">
              <div class="crm-topbar">
                <div>
                  <div class="crumb">Admisiones / Otoño 2026</div>
                  <div class="ctitle">Pipeline</div>
                </div>
                <div class="av"><span class="ring">JR</span>Julia · Lead de Admisiones</div>
              </div>
              <div class="crm-stats">
                <div class="crm-stat">
                  <div class="lbl">Leads activos</div>
                  <div class="val" data-count="428">428</div>
                  <div class="delta">▲ 12% esta sem.</div>
                </div>
                <div class="crm-stat">
                  <div class="lbl">Leads calientes</div>
                  <div class="val" data-count="34">34</div>
                  <div class="delta">▲ 6 hoy</div>
                </div>
                <div class="crm-stat">
                  <div class="lbl">Resp. promedio</div>
                  <div class="val">2.4<span class="small">s</span></div>
                  <div class="delta">vs 4.2h antes</div>
                </div>
                <div class="crm-stat">
                  <div class="lbl">Conversión</div>
                  <div class="val">28<span class="small">%</span></div>
                  <div class="delta">▲ 9pts AoA</div>
                </div>
              </div>
              <div class="crm-kanban">
                <div class="crm-col">
                  <h5>Nuevo <span class="count">42</span></h5>
                  <div class="lead-card cold"><div class="nm">Luca Chen</div><div class="meta">ES-118 · hace 2m</div><div class="score-pill cold"><i></i>18 Frío</div></div>
                  <div class="lead-card cold"><div class="nm">R. Ortiz</div><div class="meta">ES-117 · hace 14m</div><div class="score-pill cold"><i></i>22 Frío</div></div>
                </div>
                <div class="crm-col">
                  <h5>Calificando <span class="count">28</span></h5>
                  <div class="lead-card warm"><div class="nm">Aisha Brown</div><div class="meta">ES-101 · Grado 9</div><div class="score-pill warm"><i></i>48 Tibio</div></div>
                  <div class="lead-card warm"><div class="nm">Joon Kang</div><div class="meta">ES-095 · Prog. IB</div><div class="score-pill warm"><i></i>53 Tibio</div></div>
                </div>
                <div class="crm-col">
                  <h5>Tibio <span class="count">19</span></h5>
                  <div class="lead-card warm moving"><div class="nm">Noor Singh</div><div class="meta">Visita: 14 ago</div><div class="score-pill warm"><i></i>64 Tibio</div></div>
                  <div class="lead-card warm"><div class="nm">Pablo Diaz</div><div class="meta">2 hermanos · K3</div><div class="score-pill warm"><i></i>68 Tibio</div></div>
                </div>
                <div class="crm-col">
                  <h5>Caliente <span class="count">9</span></h5>
                  <div class="lead-card hot"><div class="nm">Maya Patel</div><div class="meta">Visitó · esp. oferta</div><div class="score-pill hot"><i></i>87 Cal.</div></div>
                  <div class="lead-card hot"><div class="nm">Sofía Reyes</div><div class="meta">Sol. enviada</div><div class="score-pill hot"><i></i>92 Cal.</div></div>
                </div>
                <div class="crm-col">
                  <h5>Cerrando <span class="count">5</span></h5>
                  <div class="lead-card hot"><div class="nm">Tomás Vega</div><div class="meta">Oferta enviada</div><div class="score-pill hot"><i></i>95 Cal.</div></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
  .device {
    position: relative;
    background: var(--color-ink-2);
    border-radius: 28px;
    padding: 14px;
    border: 1px solid rgba(242,239,230,0.08);
    box-shadow: 0 40px 80px rgba(0,0,0,0.5), 0 10px 20px rgba(0,0,0,0.3);
  }
  .device-screen {
    background: var(--color-paper);
    border-radius: 18px;
    overflow: hidden;
    color: var(--color-ink);
  }
  .crm-mock { display: flex; flex-direction: column; min-height: 460px; }

  .crm-topbar {
    padding: 14px 20px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid var(--color-ink-line);
    background: var(--color-cream);
  }
  .crumb { font-family: var(--font-mono); font-size: 10px; color: var(--color-ink-mute); text-transform: uppercase; letter-spacing: 0.1em; }
  .ctitle { font-family: var(--font-serif); font-style: italic; font-size: 22px; line-height: 1; letter-spacing: -0.01em; color: var(--color-ink); margin-top: 2px; }
  .av {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; color: var(--color-ink);
    padding: 5px 10px;
    background: var(--color-paper); border: 1px solid var(--color-ink-line);
    border-radius: 999px;
  }
  .ring {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--color-lime);
    display: inline-flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: 9px; font-weight: 600;
    color: var(--color-moss);
  }

  .crm-stats {
    padding: 16px 20px;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px;
    border-bottom: 1px solid var(--color-ink-line);
  }
  .crm-stat .lbl { font-family: var(--font-mono); font-size: 9px; color: var(--color-ink-mute); text-transform: uppercase; letter-spacing: 0.1em; }
  .crm-stat .val { margin-top: 4px; font-size: 26px; font-weight: 500; letter-spacing: -0.025em; color: var(--color-ink); }
  .crm-stat .val .small { font-size: 14px; color: var(--color-ink-mute); font-weight: 400; }
  .crm-stat .delta { margin-top: 2px; font-family: var(--font-mono); font-size: 10px; color: var(--color-moss); }

  .crm-kanban {
    flex: 1; padding: 16px 20px 22px;
    display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;
  }
  .crm-col { display: flex; flex-direction: column; gap: 8px; }
  .crm-col h5 {
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-mono); font-size: 9px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--color-ink-mute);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-ink-line);
  }
  .count { background: rgba(14,13,10,0.06); padding: 2px 6px; border-radius: 999px; font-size: 9px; color: var(--color-ink-2); }

  .lead-card {
    background: var(--color-paper);
    border: 1px solid var(--color-ink-line);
    border-radius: 8px; padding: 10px;
    font-size: 11px;
    display: flex; flex-direction: column; gap: 6px;
    box-shadow: 0 1px 3px rgba(14,13,10,0.06);
  }
  .lead-card.hot { background: var(--color-lime); border-color: var(--color-lime-dk); }
  .lead-card.moving { animation: card-move 6s ease-in-out infinite; }
  .nm { font-weight: 600; font-size: 12px; color: var(--color-ink); }
  .meta { font-family: var(--font-mono); font-size: 9px; color: var(--color-ink-mute); }
  .score-pill {
    display: inline-flex; align-items: center; gap: 4px;
    font-family: var(--font-mono); font-size: 9px; font-weight: 600;
    padding: 2px 7px; border-radius: 999px; width: fit-content;
  }
  .score-pill i { width: 5px; height: 5px; border-radius: 50%; display: block; }
  .score-pill.cold { background: rgba(127,181,229,0.18); color: #2C5C8F; }
  .score-pill.cold i { background: #5B9EC9; }
  .score-pill.warm { background: rgba(243,112,86,0.15); color: #C04A28; }
  .score-pill.warm i { background: #E07050; }
  .score-pill.hot  { background: var(--color-moss); color: var(--color-lime); }
  .score-pill.hot  i { background: var(--color-lime); }
</style>
