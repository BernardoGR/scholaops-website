---
---
<section class="hero">
  <div class="wrap">
    <div class="hero-grid">

      <!-- Text -->
      <div class="hero-text">
        <span class="eyebrow"><span class="pulse"></span>scholaops.ai — Ahora en beta</span>
        <div class="hero-chips">
          <span class="wa-chip">
            <svg viewBox="0 0 32 32" fill="currentColor" width="14" height="14"><path d="M16 3C8.82 3 3 8.82 3 16c0 2.31.61 4.46 1.66 6.32L3 29l6.85-1.62A12.93 12.93 0 0 0 16 29c7.18 0 13-5.82 13-13S23.18 3 16 3zm0 23.6c-1.96 0-3.8-.53-5.38-1.45l-.39-.23-3.99.94.95-3.88-.25-.4A10.55 10.55 0 0 1 5.4 16c0-5.85 4.76-10.6 10.6-10.6 5.85 0 10.6 4.75 10.6 10.6 0 5.85-4.75 10.6-10.6 10.6zm5.93-7.95c-.32-.16-1.92-.95-2.22-1.06-.3-.11-.52-.16-.74.16-.22.32-.85 1.06-1.04 1.28-.19.22-.38.24-.7.08-.32-.16-1.36-.5-2.59-1.6-.96-.85-1.6-1.91-1.79-2.23-.19-.32-.02-.49.14-.65.15-.14.32-.38.48-.57.16-.19.21-.32.32-.54.11-.22.05-.41-.03-.57-.08-.16-.74-1.78-1.02-2.44-.27-.64-.54-.55-.74-.56h-.63c-.22 0-.57.08-.87.41-.3.32-1.14 1.11-1.14 2.71 0 1.6 1.17 3.14 1.33 3.36.16.22 2.3 3.51 5.57 4.92.78.34 1.39.54 1.86.69.78.25 1.49.21 2.05.13.62-.09 1.92-.78 2.19-1.54.27-.76.27-1.41.19-1.54-.08-.13-.3-.21-.62-.37z"/></svg>
            WhatsApp incluido
          </span>
        </div>
        <h1 class="hero-title">
          El <span class="italic-word">sistema operativo</span>
          de admisiones para escuelas <span class="lime-swipe">modernas</span>.
        </h1>
        <p class="hero-sub">
          scholaops une un agente AI 24/7 que conversa con familias en tu sitio web y en WhatsApp, con un CRM que ya sabe quién está caliente, quién está estancado y a quién llamar primero. Un solo hilo, todos los canales.
        </p>
        <div class="hero-cta-row">
          <a href="#cta" class="btn btn-primary">
            Agenda una demo
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href="#widget" class="btn btn-ghost">
            Míralo en 90 seg
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </a>
        </div>
        <div class="hero-fineprint">
          <span>DEMO EN VIVO</span><span class="dot"></span>
          <span>INSTALACIÓN INCLUIDA</span><span class="dot"></span>
          <span>EN VIVO EN 24H</span>
        </div>
      </div>

      <!-- Stage -->
      <div class="hero-stage" aria-hidden="true">
        <div class="phone">
          <div class="phone-screen">
            <div class="phone-notch"></div>
            <div class="phone-bar">
              <span>9:41</span>
              <span class="signal"><i></i><i></i><i></i><i></i></span>
            </div>
            <div class="widget-head">
              <div class="avatar">
                <span class="live-dot"></span>
              </div>
              <div>
                <h4>Ada — Agente de Admisiones</h4>
                <p>En línea · responde al instante</p>
              </div>
            </div>
            <div class="chat-area" id="heroChat"></div>
            <div class="phone-input">
              <div class="fake-input">Escribe tu mensaje…</div>
              <div class="send">↑</div>
            </div>
          </div>
        </div>

        <!-- Float: score -->
        <div class="float-card float-score">
          <div class="fc-label">Score · En vivo</div>
          <div class="fc-name">Maya Patel</div>
          <div class="fc-meta">9.º grado · Sept 2026</div>
          <div class="gauge-head">
            <span class="gauge-num" id="scoreNum">72</span>
            <span class="gauge-tag">Lead caliente</span>
          </div>
          <div class="gauge-bar-row">
            <span class="gauge-label">Frío</span>
            <div class="gauge"><i></i></div>
            <span class="gauge-label">Caliente</span>
          </div>
        </div>

        <!-- Float: WhatsApp handoff -->
        <div class="float-card float-wa">
          <div class="fc-label">✨ Continuó en WhatsApp</div>
          <div class="wa-bub in">¿Continuamos aquí?</div>
          <div class="wa-bub out">Sí, por favor 👍</div>
          <div class="wa-meta">Contexto preservado</div>
        </div>

        <!-- Float: pipeline -->
        <div class="float-card float-pipeline">
          <div class="fc-label">Pipeline · Hoy</div>
          <div class="fc-pipe-grid">
            <div class="col"><span>Nuevo</span><div class="card"></div><div class="card move"></div><div class="card"></div></div>
            <div class="col"><span>Eval.</span><div class="card"></div><div class="card"></div></div>
            <div class="col"><span>Tibio</span><div class="card"></div><div class="card"></div><div class="card"></div></div>
            <div class="col"><span>Cal.</span><div class="card hot"></div><div class="card hot move" style="animation-delay:-2s;"></div></div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<style is:global>
  .hero { padding: 56px 0 96px; position: relative; overflow: hidden; }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  .hero-grid > * { min-width: 0; }
  @media (max-width: 980px) { .hero-grid { grid-template-columns: 1fr; gap: 48px; } }

  .hero-chips { margin-top: 16px; }
  .wa-chip {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono); font-size: 11px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: #1a7c44;
    background: rgba(37,211,102,0.1);
    border: 1px solid rgba(37,211,102,0.25);
    padding: 5px 12px;
    border-radius: 999px;
  }

  h1.hero-title {
    margin-top: 22px;
    font-family: var(--font-sans); font-weight: 500;
    font-size: clamp(44px,6.8vw,88px);
    line-height: 0.98; letter-spacing: -0.035em;
    color: var(--color-ink);
  }
  .lime-swipe {
    position: relative; display: inline-block;
    padding: 0 0.1em; isolation: isolate;
  }
  .lime-swipe::before {
    content: '';
    position: absolute; inset: 0.15em -0.05em 0.18em -0.05em;
    background: var(--color-lime);
    z-index: -1; transform: skewX(-6deg); border-radius: 4px;
  }
  .hero-sub {
    margin-top: 28px; font-size: 18px; line-height: 1.55;
    color: var(--color-ink-mute); max-width: 520px;
  }
  .hero-cta-row { margin-top: 36px; display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .hero-fineprint {
    margin-top: 22px;
    display: flex; align-items: center; gap: 14px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--color-ink-mute); text-transform: uppercase; letter-spacing: 0.1em;
    flex-wrap: wrap;
  }
  .hero-fineprint .dot { width: 3px; height: 3px; border-radius: 50%; background: var(--color-ink-line); }

  /* Stage */
  .hero-stage {
    position: relative;
    width: 100%; max-width: 540px;
    height: 560px;
    margin-left: auto;
  }
  @media (max-width: 980px) {
    .hero-stage { margin: 0 auto; height: 480px; max-width: 400px; overflow: hidden; }
    .phone      { max-width: 260px; }
  }
  @media (max-width: 768px) {
    .hero-stage     { display: none; }
  }
  .hero-stage::before {
    content: '';
    position: absolute; inset: 6% -2% 4% 4%;
    background: var(--color-cream-2);
    border-radius: 24px; border: 1px solid var(--color-ink-line); z-index: 0;
  }
  .hero-stage::after {
    content: '';
    position: absolute; left: 6%; top: 8%; width: 38%; height: 38%;
    background: radial-gradient(circle at 30% 30%, rgba(215,242,107,0.55), transparent 60%);
    filter: blur(40px); z-index: 0;
    animation: drift 9s ease-in-out infinite alternate;
  }

  /* Phone */
  .phone {
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%,-50%);
    width: 78%; max-width: 360px;
    aspect-ratio: 9/17.5;
    background: var(--color-ink);
    border-radius: 40px; padding: 12px;
    box-shadow: 0 30px 60px rgba(14,13,10,0.22), 0 10px 20px rgba(14,13,10,0.12), inset 0 0 0 1px rgba(255,255,255,0.04);
    z-index: 2;
  }
  .phone-screen {
    width: 100%; height: 100%;
    background: linear-gradient(180deg,#F3EFE3 0%,#EAE4D2 100%);
    border-radius: 30px; overflow: hidden;
    position: relative; display: flex; flex-direction: column;
  }
  .phone-notch {
    position: absolute; top: 8px; left: 50%; transform: translateX(-50%);
    width: 90px; height: 22px; background: var(--color-ink); border-radius: 999px; z-index: 5;
  }
  .phone-bar {
    padding: 14px 18px 8px;
    display: flex; align-items: center; justify-content: space-between;
    font-family: var(--font-mono); font-size: 10px; color: var(--color-ink); font-weight: 600;
  }
  .phone-bar .signal { display: flex; align-items: flex-end; gap: 3px; }
  .phone-bar .signal i { display: inline-block; width: 3px; background: var(--color-ink); border-radius: 1px; }
  .phone-bar .signal i:nth-child(1) { height: 4px; }
  .phone-bar .signal i:nth-child(2) { height: 6px; }
  .phone-bar .signal i:nth-child(3) { height: 8px; }
  .phone-bar .signal i:nth-child(4) { height: 10px; }
  .widget-head {
    padding: 4px 18px 12px;
    display: flex; align-items: center; gap: 10px;
    border-bottom: 1px solid rgba(14,13,10,0.06);
  }
  .widget-head .avatar {
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--color-ink);
    display: inline-flex; align-items: center; justify-content: center;
    position: relative; flex-shrink: 0;
  }
  .widget-head .avatar::before {
    content: ''; position: absolute; inset: 7px;
    background: var(--color-lime); border-radius: 4px; transform: rotate(45deg) scale(0.85);
  }
  .widget-head .avatar::after {
    content: ''; position: absolute; left: 50%; top: 50%;
    width: 6px; height: 6px; border-radius: 50%; background: var(--color-ink);
    transform: translate(-50%,-50%);
  }
  .live-dot {
    position: absolute; right: -2px; bottom: -2px;
    width: 10px; height: 10px; border-radius: 50%;
    background: var(--color-lime-dk); border: 2px solid var(--color-paper);
  }
  .widget-head h4 { font-size: 13px; font-weight: 600; line-height: 1.2; }
  .widget-head p { font-size: 10px; color: var(--color-ink-mute); font-family: var(--font-mono); }
  .chat-area {
    flex: 1; padding: 16px 14px;
    display: flex; flex-direction: column; gap: 8px;
    overflow: hidden; position: relative;
  }
  .phone-input {
    padding: 10px 12px 14px;
    border-top: 1px solid rgba(14,13,10,0.06);
    display: flex; align-items: center; gap: 8px;
  }
  .fake-input {
    flex: 1; background: rgba(255,255,255,0.7);
    border: 1px solid rgba(14,13,10,0.08); border-radius: 999px;
    padding: 8px 14px; font-size: 11px; color: var(--color-ink-mute);
  }
  .send {
    width: 32px; height: 32px; background: var(--color-ink); border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--color-paper); font-size: 14px; flex-shrink: 0;
  }

  /* Float cards */
  .float-card {
    position: absolute;
    background: var(--color-paper);
    border: 1px solid var(--color-ink-line);
    border-radius: 16px; padding: 14px;
    box-shadow: var(--shadow-lg);
    z-index: 3;
    animation: bob 6s ease-in-out infinite alternate;
  }
  .float-score { top: 6%; right: -2%; width: 200px; animation-delay: -1s; }
  .float-wa    { top: 38%; right: -6%; width: 190px; animation-delay: -2s; }
  .float-pipeline { bottom: 4%; left: -4%; width: 220px; animation-delay: -3s; }
  @media (max-width: 980px) {
    .float-score    { right: 2%; }
    .float-wa       { right: 0; }
    .float-pipeline { left: 2%; }
  }
  @media (max-width: 768px) {
    .float-score    { display: none; }
    .float-wa       { display: none; }
    .float-pipeline { display: none; }
  }
  .fc-label { font-family: var(--font-mono); font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-ink-mute); margin-bottom: 8px; }
  .fc-name  { font-size: 13px; font-weight: 600; }
  .fc-meta  { font-size: 11px; color: var(--color-ink-mute); margin-bottom: 10px; font-family: var(--font-mono); }
  .gauge-head { display: flex; align-items: center; gap: 8px; margin-bottom: 6px; }
  .gauge-num { font-size: 22px; font-weight: 700; letter-spacing: -0.03em; font-family: var(--font-sans); }
  .gauge-tag { font-family: var(--font-mono); font-size: 9px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-moss); background: rgba(215,242,107,0.3); padding: 2px 6px; border-radius: 4px; }
  .gauge-bar-row { display: flex; align-items: center; gap: 6px; }
  .gauge-label { font-family: var(--font-mono); font-size: 9px; color: var(--color-ink-mute); text-transform: uppercase; white-space: nowrap; }
  .gauge { flex: 1; height: 6px; background: var(--color-ink-line-2); border-radius: 3px; overflow: hidden; }
  .gauge i { display: block; height: 100%; width: 0%; background: linear-gradient(90deg, var(--color-lime), var(--color-lime-dk)); border-radius: 3px; animation: fill-gauge 2.4s cubic-bezier(0.65,0,0.35,1) infinite alternate; }

  /* WA float */
  .wa-bub { font-size: 11px; padding: 6px 10px; border-radius: 10px; margin-bottom: 4px; }
  .wa-bub.in  { background: #fff; border: 1px solid rgba(14,13,10,0.06); align-self: flex-start; }
  .wa-bub.out { background: var(--color-ink); color: var(--color-paper); }
  .wa-meta    { font-family: var(--font-mono); font-size: 9px; color: var(--color-moss); text-transform: uppercase; letter-spacing: 0.08em; margin-top: 6px; }

  /* Pipeline float */
  .fc-pipe-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 4px; }
  .fc-pipe-grid .col { display: flex; flex-direction: column; gap: 3px; }
  .fc-pipe-grid .col span { font-family: var(--font-mono); font-size: 8px; color: var(--color-ink-mute); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px; }
  .fc-pipe-grid .card { height: 18px; background: var(--color-cream); border: 1px solid var(--color-ink-line); border-radius: 4px; overflow: hidden; }
  .fc-pipe-grid .card.hot { background: var(--color-lime); border-color: var(--color-lime-dk); }
  .fc-pipe-grid .card.move { animation: pipe-move 4s ease-in-out infinite; }
</style>

<script>
  const heroChat = document.getElementById('heroChat');
  const heroScript = [
    { kind: 'in',     text: '¡Hola! Soy Ada 🌱 ¿Buscas Northcliffe para tu hijo?' },
    { kind: 'out',    text: 'Sí — 1.º de secundaria, idealmente entrando en agosto.' },
    { kind: 'typing' },
    { kind: 'ai',     text: 'Excelente. 1.º aún tiene 4 lugares para Ago 2026. Colegiatura $14,200/año con descuentos por hermanos.' },
    { kind: 'out',    text: '¿Podría visitar el campus primero?' },
    { kind: 'ai',     text: 'Por supuesto — hay open house el 14 de agosto, 10am. ¿Te aparto un lugar? 📍' },
    { kind: 'out',    text: '¡Sí, por favor!' },
    { kind: 'ai',     text: 'Listo. Te envié la confirmación. ¿Algo más? ✨' },
  ];

  function wait(ms: number) { return new Promise(r => setTimeout(r, ms)); }

  async function runHeroChat() {
    if (!heroChat) return;
    heroChat.innerHTML = '';
    for (const m of heroScript) {
      if (m.kind === 'typing') {
        const t = document.createElement('div');
        t.className = 'typing';
        t.innerHTML = '<i></i><i></i><i></i>';
        heroChat.appendChild(t);
        await wait(900);
        t.remove();
        continue;
      }
      const b = document.createElement('div');
      b.className = 'bubble ' + m.kind;
      if (m.kind === 'ai') {
        b.innerHTML = '<div class="tag"><span class="pulse-s"></span>Ada · AI</div>' + (m.text ?? '');
      } else {
        b.textContent = m.text ?? '';
      }
      heroChat.appendChild(b);
      while (heroChat.children.length > 4) heroChat.firstChild?.remove();
      await wait(m.kind === 'in' ? 1400 : 1800);
    }
    await wait(1200);
    runHeroChat();
  }
  runHeroChat();

  // Score counter animation
  const scoreEl = document.getElementById('scoreNum');
  if (scoreEl) {
    let val = 22, dir = 1;
    setInterval(() => {
      val += dir * (2 + Math.random() * 3);
      if (val >= 88) { val = 88; dir = -1; }
      if (val <= 22) { val = 22; dir =  1; }
      scoreEl.textContent = String(Math.round(val));
    }, 240);
  }
</script>
